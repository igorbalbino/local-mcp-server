{
    "name": "igorbalbino/local-mcp",
    "description": "Local MCP Server - Model Context Protocol server for AI agents",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Igor",
            "email": "igor.santo.comercial@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.14",
        "mcp/sdk": "^0.3",
        "monolog/monolog": "^3.10",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "ramsey/uuid": "^4.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "LocalMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LocalMcp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src tests --level=6",
        "cs-fix": "php-cs-fixer fix --dry-run --diff"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
