# Application
APP_NAME=Local MCP Server
APP_ENV=production
LOG_LEVEL=info
APP_PORT=8090

# MCP Server (optional overrides; defaults come from Version::NAME + VERSION file)
MCP_SERVER_NAME=Local MCP Server
MCP_SERVER_VERSION=

# Client authentication
# LOCAL_MCP_AUTH_MODE:
#   auto   = require key when LOCAL_MCP_API_KEYS is set (default)
#   none   = open access (trusted LAN / docker network — easiest for Home Assistant)
#   bearer = always require a key
LOCAL_MCP_AUTH_MODE=none

# Comma-separated API keys. Use URL-safe characters (letters, numbers, - _).
# Leave empty when LOCAL_MCP_AUTH_MODE=none.
# Ways to authenticate (controlled by LOCAL_MCP_AUTH_LOCATION):
#   1) Authorization: Bearer <key>          (Cursor, Inspector, most agents)
#   2) http://host:8090/mcp/<key>             (Home Assistant — paste URL only)
#   3) http://host:8090/mcp?api_key=<key>     (fallback)
LOCAL_MCP_API_KEYS=

# Which credential locations are accepted (comma-separated). Default: header,path,query
LOCAL_MCP_AUTH_LOCATION=header,path,query

# Hostnames allowed by DNS-rebinding protection (added to localhost + local-mcp)
# Example: homeassistant.local,192.168.1.10
LOCAL_MCP_ALLOWED_HOSTS=

# CORS allowed origins for the MCP transport middleware (* = all; default)
LOCAL_MCP_CORS_ORIGINS=*

# Home Assistant (REST tools ha_* — optional; different from connecting HA as MCP client)
ENABLE_HOME_ASSISTANT=false
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# SearXNG
ENABLE_SEARXNG=false
SEARXNG_URL=http://searxng:8080
SEARXNG_API_KEY=

# Browserless
ENABLE_BROWSERLESS=false
BROWSERLESS_URL=http://browserless:3000
BROWSERLESS_TOKEN=

# Meilisearch (RAG)
ENABLE_MEILISEARCH=false
MEILI_URL=http://meilisearch:7700
MEILI_KEY=
MEILI_INDEX=documents

# LibreTranslate
ENABLE_LIBRETRANSLATE=false
LIBRETRANSLATE_URL=http://libretranslate:5000
LIBRETRANSLATE_API_KEY=
