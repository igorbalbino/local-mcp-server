# Application
APP_NAME=Local MCP Server
APP_ENV=production
LOG_LEVEL=info
APP_PORT=8090

# MCP Server (optional overrides; defaults come from Version::NAME + VERSION file)
MCP_SERVER_NAME=Local MCP Server
MCP_SERVER_VERSION=

# Client authentication (comma-separated API keys)
# Authorization: Bearer <key>
JARVIS_API_KEYS=change-me-to-a-secure-key

# Home Assistant
ENABLE_HOME_ASSISTANT=false
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# SearXNG
ENABLE_SEARXNG=false
SEARXNG_URL=http://searxng:8080
SEARXNG_API_KEY=

# Browserless
ENABLE_BROWSERLESS=false
BROWSERLESS_URL=http://browserless:3000
BROWSERLESS_TOKEN=

# Meilisearch (RAG)
ENABLE_MEILISEARCH=false
MEILI_URL=http://meilisearch:7700
MEILI_KEY=
MEILI_INDEX=documents

# LibreTranslate
ENABLE_LIBRETRANSLATE=false
LIBRETRANSLATE_URL=http://libretranslate:5000
LIBRETRANSLATE_API_KEY=
